SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
APP_ENV=development
LOG_LEVEL=INFO
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# CORS — coma-separado, sin espacios. En prod: solo el dominio público.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Sprint I2 — Chat quota ─────────────────────────────────────────────────
# Admin bypass: emails que tienen quota ilimitada (no se cuentan ni bloquean).
# Coma-separado, lowercase comparado.
ADMIN_EMAILS=lfgg2000@gmail.com

# Límites por plan (modificables sin migration). Valores aceptados:
#   un número entero   → ese cap
#   "unlimited"/"-1"   → sin límite
#   ""/no seteado      → fallback al default codeado en quota.py:PLAN_DEFAULTS
#
# Defaults: trial 5/50, esencial 10/200, profesional 50/unlimited, empresa unlimited.
PLAN_TRIAL_DAILY=5
PLAN_TRIAL_MONTHLY=50
PLAN_ESENCIAL_DAILY=10
PLAN_ESENCIAL_MONTHLY=200
PLAN_PROFESIONAL_DAILY=50
PLAN_PROFESIONAL_MONTHLY=unlimited
PLAN_EMPRESA_DAILY=unlimited
PLAN_EMPRESA_MONTHLY=unlimited
